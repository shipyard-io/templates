# ==========================================
# GITHUB SECRETS CONFIGURATION FILE
# ==========================================
# WARNING: NEVER push the actual secrets file (.env.secrets) to GitHub!
# Fill in your real values in .env.secrets and run `gh secret set -f .env.secrets`

# 1. SERVER INFORMATION (VPS)
SERVER_IP=1.2.3.4
SERVER_USER=ubuntu
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
(Insert your private key content here)
-----END OPENSSH PRIVATE KEY-----"

# 2. TRAEFIK & DOMAIN CONFIGURATION
DOMAIN=yourdomain.com
TRAEFIK_DASHBOARD_AUTH="admin:$apr1$..."

# 3. CLOUDFLARE ORIGIN CERTIFICATES (Multiline)
CLOUDFLARE_ORIGIN_CERT="-----BEGIN CERTIFICATE-----
(Insert your certificate content here)
-----END CERTIFICATE-----"

CLOUDFLARE_ORIGIN_KEY="-----BEGIN PRIVATE KEY-----
(Insert your private key content here)
-----END PRIVATE KEY-----"

# 4. TELEGRAM NOTIFICATIONS (Optional)
TELEGRAM_BOT_TOKEN="123456789:AA..."
TELEGRAM_CHAT_ID="-100..."
